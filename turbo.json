{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "apps/landing/.next/**", "apps/dashboard/dist/**", "apps/ravoxchat/dist/**"],
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "API_BASE_URL",
        "WEB_BASE_URL",
        "JWT_SECRET",
        "API_KEY_SECRET",
        "ENCRYPTION_KEY",
        "WORKER_SECRET",
        "SESSION_STORAGE_PATH",
        "BAILEYS_AUTH_STORE",
        "CORS_ORIGINS",
        "DISK",
        "MEDIA_STORAGE_MODE",
        "MEDIA_RETENTION_DAYS",
        "STORAGE_BASE_URL",
        "R2_ENDPOINT",
        "R2_REGION",
        "R2_BUCKET",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "WORKER_REPLICAS",
        "WORKER_LOCK_TTL_MS",
        "VITE_API_BASE_URL",
        "NEXT_PUBLIC_DASHBOARD_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
