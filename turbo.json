{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "apps/web/dist/**"],
      "env": [
        "DATABASE_URL",
        "REDIS_URL",
        "API_BASE_URL",
        "WEB_BASE_URL",
        "JWT_SECRET",
        "API_KEY_SECRET",
        "ENCRYPTION_KEY",
        "WORKER_SECRET",
        "SESSION_STORAGE_PATH",
        "VITE_API_BASE_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    }
  }
}
