# Copy to .env.infra.prod and run:
#   bash infra/pulumi/setup-infra-config.sh prod

PROJECT_ID="your-gcp-project-id"
BILLING_ACCOUNT_ID="billingAccounts/000000-000000-000000"
REGION="southamerica-east1"

API_BASE_URL="https://api.seudominio.com"
WEB_BASE_URL="https://dashboard.seudominio.com"
CORS_ORIGINS="https://dashboard.seudominio.com,https://chat.seudominio.com"

CLOUD_RUN_SERVICE_NAME="ravoxzap-api"
WORKER_NAME="ravoxzap-worker"
CLOUD_RUN_MIGRATION_JOB_NAME="ravoxzap-migrate"
ARTIFACT_REGISTRY_REPOSITORY="ravoxzap"
API_IMAGE_NAME="api"
WORKER_IMAGE_NAME="worker"
INITIAL_API_IMAGE_DIGEST=""
INITIAL_WORKER_IMAGE_DIGEST=""

CLOUD_SQL_INSTANCE_NAME="ravoxzap-pg"
CLOUD_SQL_DATABASE_NAME="ravoxzap"
CLOUD_SQL_APP_USER="ravoxzap_app"
CLOUD_SQL_MACHINE_TIER="db-f1-micro"
CLOUD_SQL_DISK_GB="10"
DB_CONNECTION_GUARDRAIL="40"
DATABASE_POOL_MAX="3"

REDIS_INSTANCE_NAME="ravoxzap-redis"
REDIS_MEMORY_GB="1"

CLOUD_RUN_MIN_INSTANCES="1"
CLOUD_RUN_MAX_INSTANCES="10"
CLOUD_RUN_CONCURRENCY="80"
CLOUD_RUN_CPU="1"
CLOUD_RUN_MEMORY="1Gi"

WORKER_REPLICAS="2"
WORKER_CPU="500m"
WORKER_MEMORY="1Gi"
WORKER_LOCK_TTL_MS="30000"

STORAGE_BASE_URL="https://pub-your-r2-domain.example.com"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_REGION="us-east-1"
R2_BUCKET="ravoxzap-media"
MEDIA_RETENTION_DAYS="7"
R2_ACCESS_KEY_ID="replace-me"
R2_SECRET_ACCESS_KEY="replace-me"

JWT_SECRET="replace-me-min-16"
API_KEY_SECRET="replace-me-min-16"
ENCRYPTION_KEY="replace-me-32-byte-encryption-key"
WORKER_SECRET="replace-me-min-16"

ENABLE_BUDGET_ALERTS="true"
MONTHLY_BUDGET_USD="50"

GITHUB_OWNER=""
GITHUB_REPO_NAME=""
GITHUB_BRANCH_REGEX="^main$"
