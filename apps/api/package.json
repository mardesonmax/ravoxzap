    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.4.0",
    "@ravoxzap/auth": "0.1.0",
    "@ravoxzap/config": "0.1.0",
    "@ravoxzap/database": "0.1.0",
    "@ravoxzap/logger": "0.1.0",
    "@ravoxzap/queue": "0.1.0",
    "@ravoxzap/shared": "0.1.0",
    "@scalar/fastify-api-reference": "^1.35.1",
    "fastify": "^5.2.0",
    "nanoid": "^5.1.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
