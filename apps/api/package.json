{
  "name": "@ravoxzap/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file ../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file ../../.env dist/server.js",
